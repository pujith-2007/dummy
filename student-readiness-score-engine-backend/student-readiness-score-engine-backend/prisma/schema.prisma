generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  performanceAnalyses PerformanceAnalysis[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model PerformanceAnalysis {
  id                String                   @id @default(cuid())
  studentId         String
  assessmentId      String?
  totalQuestions    Int
  attemptedQuestions Int
  correctAnswers    Int
  scorePercentage   Float
  accuracyPercentage Float
  grade             String
  performanceLevel  String
  strengths         Json
  weaknesses        Json
  insights          Json
  trendSummary      Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  student           User                     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topicMetrics      PerformanceTopicMetric[]

  @@index([studentId])
  @@index([assessmentId])
  @@map("performance_analyses")
}

model PerformanceTopicMetric {
  id               String             @id @default(cuid())
  analysisId       String
  topic            String
  correctAnswers   Int
  attemptedQuestions Int
  percentage       Float
  proficiency      String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  analysis         PerformanceAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("performance_topic_metrics")
}
